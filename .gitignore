# ==================================
# RV1126B 测试工具 .gitignore 配置
# ==================================

# --------------------------
# 1. 虚拟环境（完全隔离，不提交）
# --------------------------
venv/
venv_win/

# --------------------------
# 2. Python 缓存/编译文件
# --------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.pyw
*.pyz
*.pyzw

# --------------------------
# 3. VSCode 本地配置（不提交）
# --------------------------
.vscode/
*.code-workspace

# --------------------------
# 4. 项目运行时生成数据（日志/报告/固件，不提交）
# --------------------------
data/

# --------------------------
# 5. Qt UI 相关（仅保留源文件，忽略自动生成的代码）
# --------------------------
# ui/*.py
# !ui/__init__.py  # 仅保留包标记文件，其他编译生成的.py全部忽略

# --------------------------
# 6. PyInstaller 打包产物（不提交）
# --------------------------
dist/
build/
*.spec

# --------------------------
# 7. 系统垃圾文件（Windows/macOS 自动生成）
# --------------------------
Thumbs.db
.DS_Store
Desktop.ini

# --------------------------
# 8. 临时/日志文件
# --------------------------
*.log
*.tmp
*.temp
*.swp

# --------------------------
# 9. 本地自定义配置（不提交，仅保留全局配置）
# --------------------------
*.json
!utils/config.py  # 保留全局配置，本地修改的私有配置可单独加规则忽略