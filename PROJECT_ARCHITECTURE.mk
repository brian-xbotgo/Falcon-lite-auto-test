# ==============================================
# RV1126B 测试工具 - 项目架构说明
# ==============================================
# 项目名称：RV1126B_Test_Tool
# 功能描述：RV1126B 芯片设备自动化测试工具
# ==============================================

# ==============================================
# 1. 目录结构
# ==============================================
RV1126B_Test_Tool/
├── core/                  # 核心业务逻辑模块
│   ├── __init__.py        # 包初始化文件（空）
│   ├── logger.py          # 日志管理模块
│   ├── adb_manager.py     # ADB设备通信管理
│   └── test_case.py       # 测试用例数据模型
├── utils/                 # 工具类模块
│   ├── __init__.py        # 包初始化文件（空）
│   └── config.py          # 全局配置管理
├── resources/             # 资源文件目录
│   ├── __init__.py        # 包初始化文件（空）
│   └── styles.qss         # Qt界面样式表
├── ui/                    # UI界面模块
│   └── __init__.py        # 包初始化文件（空）
├── data/                  # 运行时数据目录（自动创建）
│   ├── logs/              # 日志文件存放目录
│   ├── reports/           # 测试报告存放目录
│   ├── firmware/          # 固件文件存放目录
│   └── scripts/           # 测试脚本存放目录
├── venv_win/              # Windows Python虚拟环境（忽略提交）
├── .gitignore             # Git忽略配置文件
├── requirements.txt       # Python依赖包列表
└── powershell_python_start.txt  # PowerShell执行权限配置

# ==============================================
# 2. 文件详细说明
# ==============================================

# --------------------------
# 根目录文件
# --------------------------
.gitignore
  - 作用：Git版本控制忽略配置文件
  - 说明：配置了虚拟环境、Python缓存、日志文件、打包产物等不需要提交的文件规则

requirements.txt
  - 作用：Python项目依赖包列表
  - 说明：包含项目运行所需的所有第三方库版本信息

powershell_python_start.txt
  - 作用：PowerShell执行权限配置
  - 说明：包含设置PowerShell执行策略为RemoteSigned的命令，用于解决脚本执行权限问题

# --------------------------
# core/ 核心模块
# --------------------------
core/logger.py
  - 作用：全局日志管理系统
  - 功能：
    * 配置日志输出格式（时间、级别、消息）
    * 同时输出到控制台（INFO级别以上）和文件（DEBUG级别以上）
    * 日志文件按日期时间命名，自动保存到data/logs目录
    * 提供全局logger实例供其他模块使用

core/adb_manager.py
  - 作用：ADB命令封装与设备通信管理
  - 功能：
    * 封装ADB Shell命令执行、设备列表获取、文件推送、设备重启等操作
    * 支持多设备序列号指定
    * 内置超时处理和错误日志记录
    * 提供ADBManager类供测试流程调用

core/test_case.py
  - 作用：测试用例数据模型定义
  - 功能：
    * 定义TestType枚举（自动化/人工确认）
    * 定义TestStatus枚举（等待中/执行中/通过/失败/跳过）
    * 定义TestCase数据类，包含测试项所有属性
    * 预定义DEFAULT_TEST_CASES默认测试项列表

core/__init__.py
  - 作用：Python包标识文件
  - 说明：空文件，用于标记core目录为Python包

# --------------------------
# utils/ 工具模块
# --------------------------
utils/config.py
  - 作用：全局配置管理
  - 功能：
    * 自动获取项目根目录路径
    * 配置所有数据目录（日志、报告、固件、脚本）
    * 程序启动时自动创建所有必要目录
    * 配置ADB超时时间、网络测试默认地址等参数
    * 配置测试项默认参数（重试次数、开关机循环次数等）

utils/__init__.py
  - 作用：Python包标识文件
  - 说明：空文件，用于标记utils目录为Python包

# --------------------------
# resources/ 资源模块
# --------------------------
resources/styles.qss
  - 作用：Qt界面样式表
  - 功能：
    * 定义应用程序全局UI样式（暗黑主题）
    * 配置主窗口、标签页、按钮、输入框、表格、进度条等控件样式
    * 定义特殊按钮（开始/停止）的差异化样式
    * 配置字体、颜色、边框、圆角等视觉属性

resources/__init__.py
  - 作用：Python包标识文件
  - 说明：空文件，用于标记resources目录为Python包

# --------------------------
# ui/ 界面模块
# --------------------------
ui/__init__.py
  - 作用：Python包标识文件
  - 说明：空文件，用于标记ui目录为Python包，目前仅为目录占位

# --------------------------
# data/ 运行时数据目录
# --------------------------
data/logs/
  - 作用：日志文件存储目录
  - 说明：程序运行时自动创建，存放所有测试日志文件，文件名格式为YYYYMMDD_HHMMSS_test.log

data/reports/
  - 作用：测试报告存储目录
  - 说明：程序运行时自动创建，用于存放测试完成后生成的报告文件

data/firmware/
  - 作用：固件文件存储目录
  - 说明：程序运行时自动创建，用于存放待烧录或推送的设备固件文件

data/scripts/
  - 作用：测试脚本存储目录
  - 说明：程序运行时自动创建，用于存放自定义测试脚本文件

# ==============================================
# 3. 模块依赖关系
# ==============================================
# utils/config.py   → 无依赖（基础配置）
# core/logger.py    → 依赖 utils/config.py（日志目录配置）
# core/adb_manager.py → 依赖 core/logger.py, utils/config.py
# core/test_case.py → 无依赖（数据模型）
# 所有UI模块        → 依赖 core 模块和 resources/styles.qss

# ==============================================
# 4. 关键设计说明
# ==============================================
# 1. 日志系统采用单例模式，全局唯一logger实例
# 2. ADB命令全部封装在ADBManager类中，统一错误处理和日志记录
# 3. 测试用例使用数据类和枚举定义，类型安全且易于扩展
# 4. 所有路径配置集中在config.py，避免硬编码
# 5. 采用暗黑主题UI，适配测试工具使用场景
# 6. 运行时数据与源代码分离，便于版本控制
# ==============================================
